# NeedCart Backend Environment Variables

# ==============================================================================
# OpenRouter LLM Integration (Recommended for hackathon)
# ==============================================================================
# Set USE_LLM=true and provide OPENROUTER_API_KEY to enable LLM intent parsing.
# Default: false (uses deterministic regex parser)
USE_LLM=false
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=NeedCart

# ==============================================================================
# AWS Bedrock Integration (Alternative LLM provider)
# ==============================================================================
# Set USE_BEDROCK=true only after AWS Bedrock access is verified.
USE_BEDROCK=false
AWS_REGION=us-east-1
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# AWS Credentials (only needed when USE_BEDROCK=true)
# These are read by boto3 automatically from environment or ~/.aws/credentials
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
